<header class="relative bg-teal-200 shadow-md fixed top-0 left-0 w-full z-50 overflow-hidden">
    <!-- Montañas/ondas de fondo -->
    <div class="absolute bottom-0 left-0 w-full h-20 overflow-hidden">
        <svg viewBox="0 0 1440 320" preserveAspectRatio="none" class="w-full h-full">
            <defs>
                <linearGradient id="headerGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#A7F3D0" /> <!-- verde claro -->
                    <stop offset="100%" stop-color="#22D3EE" /> <!-- azul verdoso -->
                </linearGradient>
            </defs>
            <path fill="url(#headerGradient)" d="
                M0,100 L200,80 L400,120 L600,90 L800,110 L1000,80 L1200,100 L1440,90 L1440,320 L0,320 Z">
            </path>
            <!-- Flores decorativas -->
            <div class="absolute top-2 left-10 w-6 h-6 bg-pink-300 rounded-full opacity-70 animate-bounce-slow"></div>
            <div class="absolute top-6 right-20 w-4 h-4 bg-yellow-300 rounded-full opacity-60 animate-bounce-slow">
            </div>
            <div class="absolute top-10 left-1/2 w-5 h-5 bg-purple-300 rounded-full opacity-50 animate-bounce-slow">
            </div>
            <div class="absolute top-4 right-1/2 w-6 h-6 bg-red-300 rounded-full opacity-50 animate-bounce-slow">
            </div>
        </svg>
    </div>

    <!-- Contenido del header -->
    <div class="relative z-10 max-w-6xl mx-auto flex justify-between items-center p-4">
        <h1>
            <img src="/images/logo1.png" alt="RS Photo Studio" class="h-12 w-auto">
        </h1>
        <nav class="font-playfair">
            <ul class="flex space-x-6">
                <li><a href="/" class="hover:text-blue-200 transition">Inicio</a></li>
                <li><a href="/portfolio" class="hover:text-blue-200 transition">Portfolio</a></li>
                <li><a href="/services" class="hover:text-blue-200 transition">Servicios</a></li>
                <li><a href="/about" class="hover:text-blue-200 transition">Sobre mí</a></li>
                <li><a href="/blog" class="hover:text-blue-200 transition">Blog</a></li>
                <li><a href="/contacto" class="hover:text-blue-200 transition">Contacto</a></li>
            </ul>
        </nav>
    </div>
</header>