<script>
    const path = document.getElementById('mountainPath');

    let t = 0;

    function animateMountains() {

        t += 0.01;

        path.setAttribute('d', `
M0,${160 + 5 * Math.sin(t)}
L120,${200 + 5 * Math.cos(t)}
L250,${140 + 5 * Math.sin(t * 1.2)}
L370,${190 + 5 * Math.cos(t * 1.3)}
L500,${120 + 5 * Math.sin(t * 1.1)}
L620,${180 + 5 * Math.cos(t * 1.2)}
L750,${130 + 5 * Math.sin(t * 1.3)}
L870,${170 + 5 * Math.cos(t * 1.1)}
L1000,${110 + 5 * Math.sin(t * 1.2)}
L1120,${150 + 5 * Math.cos(t * 1.3)}
L1250,${100 + 5 * Math.sin(t * 1.1)}
L1370,${160 + 5 * Math.cos(t * 1.2)}
L1440,${120 + 5 * Math.sin(t * 1.3)}
L1440,320
L0,320 Z
`);

        requestAnimationFrame(animateMountains);

    }

    animateMountains();
</script>