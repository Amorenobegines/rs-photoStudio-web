<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Registro</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- ANIMACIÓN -->
    <style>
        .fade-in {
            animation: fadeIn 0.8s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body class="h-screen w-screen flex flex-row-reverse">

    <!-- CONTENEDOR PRINCIPAL -->
    <div class="relative w-full max-w-5xl mx-auto flex rounded-3xl overflow-hidden shadow-2xl mt-12">

        <!-- LADO IZQUIERDO (IMAGEN) -->
        <div class="hidden md:block w-1/2 relative">
            <img src="/images/foto2.jpeg" class="w-full h-full object-cover opacity-80">
            <div class="absolute inset-0 bg-black/50"></div>
        </div>

        <!-- LADO DERECHO (FORMULARIO) -->
        <div class="w-full md:w-1/2 bg-[#2a2a2a] p-10 flex flex-col justify-center">

            <!-- LOGO -->
            <div class="flex justify-center mb-6">
                <img src="/images/logo1.png" class="h-14">
            </div>

            <h2 class="text-2xl text-center text-[#c9a35c] mb-6">Crear cuenta</h2>

            <!-- ERROR -->
            <% if (error) { %>
                <div class="bg-red-500/20 border border-red-400 text-red-300 px-4 py-2 rounded-lg mb-4 text-sm">
                    <%= error %>
                </div>
                <% } %>

                    <!-- FORM -->
                    <form action="/register" method="POST" class="space-y-5">

                        <input type="email" name="email" placeholder="Email" required
                            class="w-full px-4 py-3 bg-transparent text-white placeholder-gray-300 border border-white/30 rounded-xl focus:border-[#c9a35c] focus:ring-1 focus:ring-[#c9a35c] outline-none">

                        <!-- PASSWORD CON ICONO -->
                        <div class="relative">
                            <input id="password" type="password" name="password" placeholder="Contraseña" required
                                class="w-full px-4 py-3  bg-transparent text-white border border-white/30 rounded-xl focus:border-[#c9a35c] focus:ring-1 focus:ring-[#c9a35c] outline-none">
                            <button type="button" onclick="togglePassword('password', this)"
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-300 hover:text-[#c9a35c] transition duration-200">

                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 eye-icon" fill="none"
                                    viewBox="0 0 24 24" stroke="currentColor">

                                    <!-- OJO ABIERTO -->
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 
                                        0 8.268 2.943 9.542 7-1.274 
                                        4.057-5.065 7-9.542 
                                        7-4.477 0-8.268-2.943-9.542-7z" />

                                    <!-- OJO CERRADO -->
                                    <path class="eye-closed hidden" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 
                                        19c-4.477 0-8.268-2.943-9.542-7a9.956 
                                        9.956 0 012.293-3.95M6.1 
                                        6.1A9.956 9.956 0 0112 5c4.477 
                                        0 8.268 2.943 9.542 
                                        7a9.97 9.97 0 01-4.132 
                                        5.411M15 12a3 3 0 00-3-3m0 
                                        0a3 3 0 00-3 3m3-3v6m6 
                                        6L6 6" />
                                </svg>

                            </button>
                        </div>
                        <div class="relative">
                            <input id="confirmPassword" type="password" name="confirmPassword"
                                placeholder="Confirmar contraseña" required
                                class="w-full px-4 py-3 pr-12 bg-transparent text-white border border-white/30 rounded-xl focus:border-[#c9a35c] focus:ring-1 focus:ring-[#c9a35c] outline-none">

                            <button type="button" onclick="togglePassword('confirmPassword', this)"
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-300 hover:text-[#c9a35c] transition duration-200">

                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 eye-icon" fill="none"
                                    viewBox="0 0 24 24" stroke="currentColor">

                                    <!-- OJO ABIERTO -->
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 
                                        0 8.268 2.943 9.542 7-1.274 
                                        4.057-5.065 7-9.542 
                                        7-4.477 0-8.268-2.943-9.542-7z" />

                                    <!-- OJO CERRADO -->
                                    <path class="eye-closed hidden" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 
                                        19c-4.477 0-8.268-2.943-9.542-7a9.956 
                                        9.956 0 012.293-3.95M6.1 
                                        6.1A9.956 9.956 0 0112 5c4.477 
                                        0 8.268 2.943 9.542 
                                        7a9.97 9.97 0 01-4.132 
                                        5.411M15 12a3 3 0 00-3-3m0 
                                        0a3 3 0 00-3 3m3-3v6m6 
                                        6L6 6" />
                                </svg>

                            </button>
                        </div>
                        <button
                            class="w-full py-3 bg-[#c9a35c] text-white font-semibold rounded-xl hover:bg-[#b8934f] transition">
                            REGISTRARSE
                        </button>
                        <!-- GOOGLE REGISTER -->
                        <a href="/auth/google"
                            class="flex items-center justify-center gap-3 w-full border border-white/20 py-3 rounded-xl hover:bg-white/10 transition mb-5">

                            <!-- ICONO GOOGLE -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5">
                                <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 
                                    32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 
                                    12-12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C33.6 
                                    6.1 29.1 4 24 4 12.9 4 4 12.9 4 
                                    24s8.9 20 20 20 20-8.9 
                                    20-20c0-1.3-.1-2.5-.4-3.5z" />
                                <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 
                                    16.1 19 13 24 13c3 0 5.7 1.1 
                                    7.8 2.9l5.7-5.7C33.6 6.1 29.1 
                                    4 24 4c-7.7 0-14.3 4.4-17.7 
                                    10.7z" />
                                <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 
                                    13.5-5.2l-6.2-5.1C29.1 35.6 26.7 
                                    36.5 24 36.5c-5.3 0-9.7-3.3-11.3-8l-6.5 
                                    5C9.5 39.6 16.2 44 24 44z" />
                                <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1.1 
                                    3-3.5 5.5-6.8 6.9l.1-.1 6.2 
                                    5.1C33.7 32.7 36 28.6 36 24c0-1.3-.1-2.5-.4-3.5z" />
                            </svg>

                            <span class="text-sm text-white">Registrarse con Google</span>
                        </a>
                        <!-- LINK -->
                        <p class="text-sm text-center text-gray-400 mt-6">
                            ¿Ya tienes cuenta?
                            <a href="/login" class="text-[#c9a35c] hover:underline">
                                Iniciar seción
                            </a>
                        </p>

                    </form>



        </div>
    </div>
    <!-- SCRIPT -->
    <script>
        function togglePassword(id, button) {
            const input = document.getElementById(id);
            const eyeOpen = button.querySelectorAll(".eye-open");
            const eyeClosed = button.querySelector(".eye-closed");

            if (input.type === "password") {
                input.type = "text";

                // cambiar icono
                eyeOpen.forEach(el => el.classList.add("hidden"));
                eyeClosed.classList.remove("hidden");
            } else {
                input.type = "password";

                // volver icono original
                eyeOpen.forEach(el => el.classList.remove("hidden"));
                eyeClosed.classList.add("hidden");
            }
        }
    </script>

</body>

</html>