<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Fuentes y estilos -->
    <link href="/css/style.css" rel="stylesheet">
    <link href="/css/custom.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="icon" type="image/jpeg" href="/images/logo1.png">

    <!-- Título dinámico -->
    <title>
        <%= typeof post !=='undefined' ? post.title : 'RS Photo Studio | Fotografía infantil en Dos Hermanas' %>
    </title>

    <!-- Meta description y keywords dinámicas -->
    <meta name="description"
        content="<%= typeof post !== 'undefined' ? post.description : 'RS Photo Studio es un estudio de fotografía infantil en Dos Hermanas (Sevilla). Especialistas en smash cake, maternidad, recién nacidos, comuniones y sesiones familiares.' %>">
    <meta name="keywords"
        content="<%= typeof post !== 'undefined' ? post.tags.join(', ') : 'fotografía, maternidad, newborn, comunión, smash cake, Dos Hermanas, Sevilla' %>">

    <!-- Open Graph para redes sociales -->
    <meta property="og:type" content="website">
    <meta property="og:title"
        content="<%= typeof post !== 'undefined' ? post.title : 'RS Photo Studio | Fotografía infantil en Dos Hermanas' %>">
    <meta property="og:description"
        content="<%= typeof post !== 'undefined' ? post.description : 'RS Photo Studio es un estudio de fotografía infantil en Dos Hermanas (Sevilla). Especialistas en smash cake, maternidad, recién nacidos, comuniones y sesiones familiares.' %>">
    <meta property="og:image" content="https://tudominio.com/images/logo1.png">
    <meta property="og:url" content="https://tudominio.com">
    <meta property="og:site_name" content="RS Photo Studio">

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Photographer",
      "name": "RS Photo Studio",
      "image": "https://tudominio.com/images/logo1.png",
      "url": "https://tudominio.com",
      "telephone": "+34 605652742",
      "email": "rs.photostudio.rociosanchez@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Urb. Recreo San José, 41702 Dos Hermanas, Sevilla",
        "addressLocality": "Dos Hermanas",
        "addressRegion": "Sevilla",
        "postalCode": "41701",
        "addressCountry": "ES"
      },
      "areaServed": [
        "Dos Hermanas",
        "Sevilla",
        "Alcalá de Guadaíra",
        "Utrera",
        "Los Palacios"
      ],
      "sameAs": [
        "https://www.instagram.com/rs.photostudio.rociosanchez?igsh=MWc0N3c0Zmt4YWkxdQ==",
        "https://www.facebook.com/profile.php?id=100070964383021&locale=es_ES"
         "https://wa.me/34605652742"
        ]
    }
    </script>
</head>

<body class="font-playfair text-gray-800">
    <!-- Navbar -->
    <%- include("../partials/navbar") %>

        <!-- Contenido principal -->
        <%- body %>

            <!-- Footer -->
            <%- include("../partials/footer") %>

                <!-- BOTONES FLOTANTES -->
                <div class="fixed bottom-6 right-6 flex flex-col space-y-4">
                    <a href="tel:+34605652742"
                        class="bg-blue-500 hover:bg-blue-600 text-white p-4 rounded-full shadow-xl transition transform hover:scale-110 flex items-center justify-center"
                        title="Llamar a RS Photo Studio">
                        <i class="fa-solid fa-phone"></i>
                    </a>
                    <a href="https://wa.me/34605652742" target="_blank" rel="noopener noreferrer"
                        class="bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-xl transition transform hover:scale-110 flex items-center justify-center"
                        title="WhatsApp RS Photo Studio">
                        <i class="fa-brands fa-whatsapp"></i>
                    </a>
                </div>
                </div>
</body>

</html>