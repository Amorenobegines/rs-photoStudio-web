<section class="relative z-40 w-full overflow-hidden aspect-[3/2]">



    <!-- Contenedor de imágenes -->
    <div id="slider" class="absolute inset-0 w-full h-full">
        <img src="/images/foto3.jpeg"
            class="slide absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-700">
        <img src="/images/foto2.jpeg"
            class="slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700">
        <img src="/images/foto4.jpeg"
            class="slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700">
    </div>

    <!-- Texto encima -->
    <div class="relative z-10 text-center text-white bg-black/40 h-full flex flex-col justify-center px-4">
        <h2 class="text-4xl md:text-4xl font-bold mb-4">RS Photo Studio</h2>
        <p class="max-w-3xl mx-auto mb-6">
