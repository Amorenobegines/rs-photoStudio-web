        </p>

    </div>
</section>

<script>
    const slides = document.querySelectorAll(".slide");
    let index = 0;

    setInterval(() => {
        slides[index].style.opacity = 0;
        index = (index + 1) % slides.length;
        slides[index].style.opacity = 1;
    }, 6000); // Cambia cada 6 segundos
</script>

