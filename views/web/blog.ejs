<section class="py-16 max-w-6xl mx-auto px-6">
    <h2 class="text-4xl font-bold mb-12 text-center">Blog</h2>

    <div class="grid md:grid-cols-3 gap-10">
        <% posts.forEach(post=> { %>
            <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition">
                <img src="<%= post.image %>" alt="<%= post.title %>" class="w-full h-48 object-cover">
                <div class="p-4">
                    <h3 class="text-xl font-semibold mb-2"><a href="/blog/<%= post.slug %>">
                            <%= post.title %>
                        </a></h3>
                    <p class="text-gray-600 text-sm mb-2">
                        <%= post.date %>
                    </p>
                    <p class="text-gray-700">
                        <%= post.description %>
                    </p>
                    <a href="/blog/<%= post.slug %>" class="text-teal-600 hover:underline mt-2 inline-block">Leer
                        más</a>
                </div>
            </article>
            <% }) %>
    </div>
</section>