<section class="max-w-7xl mx-auto px-6 py-20">

    <h1 class="text-4xl md:text-5xl font-bold text-center mb-6">
        Blog de RS PhotoStudio en Dos Hermanas
    </h1>

    <p class="text-center text-gray-600 mb-16 max-w-2xl mx-auto">
        Consejos y guías para preparar tu sesión de fotos: maternidad, newborn, smash cake, infantil, comunión y más.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">

        <% const servicioLinks={ "maternidad-dos-hermanas" : "/fotografia-embarazo-dos-hermanas"
            , "newborn-dos-hermanas" : "/fotografia-newborn-dos-hermanas"
            , "detalle-original-comunion-sevilla-periodico" : "/fotografia-comunion-dos-hermanas"
            , "smash-cake-dos-hermanas" : "/fotografia-smash-cake-dos-hermanas" , "fotografia-infantil-dos-hermanas"
            : "/fotografia-infantil-dos-hermanas" , "comunion-dos-hermanas" : "/fotografia-comunion-dos-hermanas"
            , "navidad-dos-hermanas" : "/fotografia-navidad-dos-hermanas" , "seguimiento-bebe-dos-hermanas"
            : "/fotografia-seguimiento-dos-hermanas" , "sesion-pareja-dos-hermanas" : "/fotografia-pareja-dos-hermanas"
            , "sesion-familiar-dos-hermanas" : "/fotografia-familiar-dos-hermanas" , "bautizo-dos-hermanas"
            : "/fotografia-bautizo-dos-hermanas" }; %>

            <% posts.forEach(post=> { %>
                <article class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition group">

                    <!-- Imagen del post -->
                    <div class="overflow-hidden">
                        <img src="<%= post.image %>" alt="<%= post.title %>" class="w-full h-56 object-cover ">
                    </div>

                    <!-- Contenido del post -->
                    <div class="p-6">
                        <p class="text-sm text-gray-400 mb-2">
                            <%= post.date %>
                        </p>

                        <h2 class="text-xl font-semibold text-gray-800 mb-3 group-hover:text-teal-600">
                            <%= post.title %>
                        </h2>

                        <p class="text-gray-600 text-sm mb-4">
                            <%= post.description %>
                        </p>

                        <!-- Enlaces -->
                        <div class="flex justify-between items-center">

                            <!-- Leer más al post completo -->
                            <a href="/blog/<%= post.slug %>" class="text-teal-600 font-semibold hover:underline">
                                Leer más →
                            </a>

                            <!-- Enlace al servicio correspondiente -->
                            <% if(servicioLinks[post.slug]) { %>
                                <a href="<%= servicioLinks[post.slug] %>"
                                    class="text-xs bg-teal-100 px-3 py-1 rounded-full">
                                    Ver sesión
                                </a>
                                <% } %>

                        </div>
                    </div>
                </article>
                <% }) %>

    </div>
</section>