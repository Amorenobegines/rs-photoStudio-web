<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO dinámico -->
    <title>
        <%= post.title %> | Fotografía en Dos Hermanas
    </title>
    <meta name="description" content="<%= post.description %>">
    <meta name="keywords" content="<%= post.tags.join(', ') %>">

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content="<%= post.title %> | Fotografía en Dos Hermanas">
    <meta property="og:description" content="<%= post.description %>">
    <meta property="og:image" content="<%= post.image %>">
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://tusitio.com/blog/<%= post.slug %>">

    <link rel="stylesheet" href="/css/tailwind.css">
</head>

<body class="bg-gray-50 text-gray-800">

    <main class="max-w-4xl mx-auto py-16 px-6">

        <!-- Imagen principal -->
        <img src="<%= post.image %>" alt="<%= post.title %>"
            class="w-full max-w-3xl mx-auto h-80 object-cover object-center rounded-2xl shadow-xl mb-8">

        <!-- Título principal -->
        <h1 class="text-4xl font-bold mb-4 text-gray-800">
            <%= post.title %>
        </h1>

        <!-- Fecha y ubicación -->
        <p class="text-gray-400 text-sm mb-8">
            <%= post.date %> · Dos Hermanas, Sevilla
        </p>

        <!-- Contenido del post -->
        <div class="prose prose-lg max-w-full">
            <%- post.content %>
        </div>
    </main>

</body>

</html>